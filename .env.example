DATABASE_URL="postgresql://ecommerce:ecommerce@localhost:5432/ecommerce"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Optional: estimated tax line item (basis points) when Stripe Tax is off
TAX_BPS="0"
# Set to true only after enabling Stripe Tax on your account
STRIPE_ENABLE_TAX="false"

# Optional: Vercel Blob for product image uploads on serverless (otherwise files go to public/uploads locally)
# BLOB_READ_WRITE_TOKEN=""
# Optional: If your Blob store is private, set this so uploads use private access.
# When private, uploaded image URLs are stored as `/api/media/blob?...` which streams from Blob server-side.
# BLOB_ACCESS="private"
